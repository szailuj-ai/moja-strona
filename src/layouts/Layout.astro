---
const { title = "Ośrodek" } = Astro.props;
const pathname = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Szargiej i Malachowska</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root { --zielony: #a8c5a0; --zielony-ciemny: #7aaa70; --zielony-jasny: #e8f2e6; --czarny: #1a1a1a; --szary: #555; --biel: #ffffff; }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Jost', sans-serif; color: var(--czarny); background: var(--biel); font-weight: 300; }
      nav { position: sticky; top: 0; z-index: 100; background: var(--biel); border-bottom: 1px solid #e5ece4; padding: 0 40px; display: flex; align-items: center; justify-content: space-between; height: 70px; }
      .nav-logo { display: flex; align-items: center; gap: 14px; text-decoration: none; color: var(--czarny); }
      .nav-logo img { height: 48px; width: auto; }
      .nav-logo-text { display: flex; flex-direction: column; line-height: 1.2; }
      .nav-logo-text span:first-child { font-weight: 300; font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--szary); }
      .nav-logo-text span:last-child { font-family: 'Cormorant Garamond', serif; font-size: 1.1rem; font-weight: 600; }
      .nav-links { display: flex; align-items: center; gap: 8px; list-style: none; }
      .nav-links a { text-decoration: none; color: var(--szary); font-size: 0.8rem; letter-spacing: 0.06em; text-transform: uppercase; padding: 6px 12px; border-radius: 4px; transition: color 0.2s, background 0.2s; }
      .nav-links a:hover { color: var(--czarny); background: var(--zielony-jasny); }
      .nav-links a.active { color: var(--zielony-ciemny); font-weight: 500; background: var(--zielony-jasny); }
      main { min-height: calc(100vh - 70px - 120px); }
      footer { background: var(--czarny); color: #aaa; padding: 40px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
      footer p { font-size: 0.8rem; font-weight: 300; }
      footer a { color: var(--zielony); text-decoration: none; font-size: 0.8rem; }
      footer a:hover { color: var(--biel); }
      .footer-links { display: flex; gap: 24px; }
      .strona-hero { background: var(--zielony-jasny); padding: 60px 80px 50px; border-bottom: 1px solid #daebd8; }
      .strona-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: 2.8rem; font-weight: 400; color: var(--czarny); margin-bottom: 12px; }
      .strona-hero p { font-size: 1rem; color: var(--szary); max-width: 600px; line-height: 1.7; }
      .strona-tresc { max-width: 960px; margin: 0 auto; padding: 60px 80px; }
      .strona-tresc h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.9rem; font-weight: 400; color: var(--czarny); margin-bottom: 16px; margin-top: 48px; }
      .strona-tresc h2:first-child { margin-top: 0; }
      .strona-tresc p { font-size: 0.95rem; line-height: 1.85; color: #444; margin-bottom: 16px; }
      @media (max-width: 768px) {
        nav { padding: 0 20px; flex-wrap: wrap; height: auto; padding-top: 12px; padding-bottom: 12px; gap: 12px; }
        .nav-links { flex-wrap: wrap; gap: 4px; }
        .nav-links a { font-size: 0.72rem; padding: 4px 8px; }
        .strona-hero { padding: 60px 80px 50px; }
        .strona-hero h1 { font-size: 2rem; }
        .strona-tresc { padding: 60px 80px; }
        footer { padding: 30px 20px; flex-direction: column; align-items: flex-start; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a href="/" class="nav-logo">
        <img src="/logo.png" alt="Logo" />
        <div class="nav-logo-text">
          <span>Ośrodek Mediacyjno-Psychologiczny</span>
          <span>Szargiej & Małachowska</span>
        </div>
      </a>
      <ul class="nav-links">
        <li><a href="/" class={pathname === "/" ? "active" : ""}>Strona główna</a></li>
        <li><a href="/o-nas" class={pathname.startsWith("/o-nas") ? "active" : ""}>O nas</a></li>
        <li><a href="/mediacje" class={pathname === "/mediacje" ? "active" : ""}>Mediacje</a></li>
        <li><a href="/szkolenia" class={pathname === "/szkolenia" ? "active" : ""}>Szkolenia</a></li>
        <li><a href="/terapia" class={pathname === "/terapia" ? "active" : ""}>Terapia</a></li>
        <li><a href="/aktualnosci" class={pathname === "/aktualnosci" ? "active" : ""}>Aktualności</a></li>
        <li><a href="/kontakt" class={pathname === "/kontakt" ? "active" : ""}>Kontakt</a></li>
        <li><a href="/jak-nas-znalezc" class={pathname === "/jak-nas-znalezc" ? "active" : ""}>Jak nas znaleźć</a></li>
      </ul>
    </nav>
    <main><slot /></main>
    <footer>
      <p>&copy; 2025 Ośrodek Mediacyjno-Psychologiczny Szargiej & Małachowska — Białystok</p>
      <div class="footer-links">
        <a href="/kontakt">Kontakt</a>
        <a href="/jak-nas-znalezc">Jak nas znaleźć</a>
        <a href="https://www.facebook.com/61558793636623" target="_blank">Facebook</a>
      </div>
    </footer>
  </body>
</html>